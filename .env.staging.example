# Staging backend defaults (Railway service mapped to `staging` branch)
FRONTEND_URL=https://<staging-vercel-domain>
ALLOW_VERCEL_PREVIEWS=true
NODE_ENV=production
JWT_SECRET=<staging-jwt-secret>
DB_PATH=/app/data/mapmat.db
TEST_AUTH_ENABLED=true
TEST_AUTH_SEED_EMAIL=matt@email.com
TEST_AUTH_SEED_PASSWORD=Admin123
TEST_AUTH_SEED_NAME=Matt Test
AUTH_HEADER_FALLBACK=true
COLLABORATION_BACKEND_ENABLED=false
COLLAB_INVITE_DEFAULT_DAYS=7
COLLAB_INVITE_MAX_DAYS=30
REALTIME_BASELINE_ENABLED=false
REALTIME_PRESENCE_TTL_SEC=90
REALTIME_PRESENCE_HEARTBEAT_SEC=20
COEDITING_EXPERIMENT_ENABLED=false
SCREENSHOT_CAPTURE_TIMEOUT_MS=60000
SCREENSHOT_CACHE_TTL_MS=3600000
SCREENSHOT_FULL_MAX_HEIGHT=16000
SCREENSHOT_FULL_MAX_WIDTH=1920
SCREENSHOT_CLEANUP_INTERVAL_MS=300000
SCREENSHOT_CLEANUP_MAX_FILES=50
RUN_MODE=both
