# Production backend defaults (Railway service mapped to `main` branch)
FRONTEND_URL=https://<production-vercel-domain>
ALLOW_VERCEL_PREVIEWS=false
NODE_ENV=production
JWT_SECRET=<production-jwt-secret>
DB_PATH=/app/data/mapmat.db
TEST_AUTH_ENABLED=false
AUTH_HEADER_FALLBACK=false
COLLABORATION_BACKEND_ENABLED=false
COLLAB_INVITE_DEFAULT_DAYS=7
COLLAB_INVITE_MAX_DAYS=30
REALTIME_BASELINE_ENABLED=false
REALTIME_PRESENCE_TTL_SEC=90
REALTIME_PRESENCE_HEARTBEAT_SEC=20
RUN_MODE=both
