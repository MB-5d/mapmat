    "verify:realtime:production:canary:window": "COEDITING_HEALTH_URL=\"https://mapmat-production.up.railway.app/health/coediting\" COEDITING_ADMIN_URL=\"https://mapmat-production.up.railway.app/api/admin/coediting\" node scripts/check-coediting-canary-window.js",
    "verify:realtime:staging:broad": "COEDITING_HEALTH_URL=\"https://mapmat-staging.up.railway.app/health/coediting\" COEDITING_ADMIN_URL=\"https://mapmat-staging.up.railway.app/api/admin/coediting\" COEDITING_REQUIRE_ALLOW_GLOBAL_ROLLOUT_FALSE=false COEDITING_REQUIRE_GLOBAL_ROLLOUT_APPROVED_FALSE=false COEDITING_EXPECT_ALLOW_GLOBAL_ROLLOUT=true COEDITING_EXPECT_GLOBAL_ROLLOUT_APPROVED=true COEDITING_MIN_SCOPED_ENTITIES=0 COEDITING_MAX_SCOPED_ENTITIES=0 node scripts/check-coediting-canary.js",
    "verify:realtime:production:broad": "COEDITING_HEALTH_URL=\"https://mapmat-production.up.railway.app/health/coediting\" COEDITING_ADMIN_URL=\"https://mapmat-production.up.railway.app/api/admin/coediting\" COEDITING_REQUIRE_ALLOW_GLOBAL_ROLLOUT_FALSE=false COEDITING_REQUIRE_GLOBAL_ROLLOUT_APPROVED_FALSE=false COEDITING_EXPECT_ALLOW_GLOBAL_ROLLOUT=true COEDITING_EXPECT_GLOBAL_ROLLOUT_APPROVED=true COEDITING_MIN_SCOPED_ENTITIES=0 COEDITING_MAX_SCOPED_ENTITIES=0 node scripts/check-coediting-canary.js",
    "verify:realtime:staging:broad:window": "COEDITING_HEALTH_URL=\"https://mapmat-staging.up.railway.app/health/coediting\" COEDITING_ADMIN_URL=\"https://mapmat-staging.up.railway.app/api/admin/coediting\" COEDITING_REQUIRE_ALLOW_GLOBAL_ROLLOUT_FALSE=false COEDITING_REQUIRE_GLOBAL_ROLLOUT_APPROVED_FALSE=false COEDITING_EXPECT_ALLOW_GLOBAL_ROLLOUT=true COEDITING_EXPECT_GLOBAL_ROLLOUT_APPROVED=true COEDITING_MIN_SCOPED_ENTITIES=0 COEDITING_MAX_SCOPED_ENTITIES=0 node scripts/check-coediting-canary-window.js",
    "verify:realtime:production:broad:window": "COEDITING_HEALTH_URL=\"https://mapmat-production.up.railway.app/health/coediting\" COEDITING_ADMIN_URL=\"https://mapmat-production.up.railway.app/api/admin/coediting\" COEDITING_REQUIRE_ALLOW_GLOBAL_ROLLOUT_FALSE=false COEDITING_REQUIRE_GLOBAL_ROLLOUT_APPROVED_FALSE=false COEDITING_EXPECT_ALLOW_GLOBAL_ROLLOUT=true COEDITING_EXPECT_GLOBAL_ROLLOUT_APPROVED=true COEDITING_MIN_SCOPED_ENTITIES=0 COEDITING_MAX_SCOPED_ENTITIES=0 node scripts/check-coediting-canary-window.js",
    "verify:realtime:staging:preflight": "COEDITING_HEALTH_URL=\"https://mapmat-staging.up.railway.app/health/coediting\" COEDITING_ADMIN_URL=\"https://mapmat-staging.up.railway.app/api/admin/coediting\" node scripts/check-coediting-rollout-preflight.js",
    "verify:realtime:production:preflight": "COEDITING_HEALTH_URL=\"https://mapmat-production.up.railway.app/health/coediting\" COEDITING_ADMIN_URL=\"https://mapmat-production.up.railway.app/api/admin/coediting\" node scripts/check-coediting-rollout-preflight.js",
    "verify:realtime:rollout-state": "COEDITING_LEFT_NAME=staging COEDITING_LEFT_HEALTH_URL=\"https://mapmat-staging.up.railway.app/health/coediting\" COEDITING_LEFT_ADMIN_URL=\"https://mapmat-staging.up.railway.app/api/admin/coediting\" COEDITING_RIGHT_NAME=production COEDITING_RIGHT_HEALTH_URL=\"https://mapmat-production.up.railway.app/health/coediting\" COEDITING_RIGHT_ADMIN_URL=\"https://mapmat-production.up.railway.app/api/admin/coediting\" node scripts/check-coediting-rollout-state.js",
    "verify:realtime:all:canary": "npm run verify:realtime:staging:canary && npm run verify:realtime:production:canary",
    "verify:realtime:all:canary:window": "npm run verify:realtime:staging:canary:window && npm run verify:realtime:production:canary:window",
    "verify:realtime:all:broad": "npm run verify:realtime:staging:broad && npm run verify:realtime:production:broad",
    "verify:realtime:all:broad:window": "npm run verify:realtime:staging:broad:window && npm run verify:realtime:production:broad:window",
    "test:ia": "node scripts/ia-test.js",
