{
  "name": "mapmat-backend",
  "version": "1.0.0",
  "description": "Map Mat - Visual sitemap generator backend",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "start:worker": "RUN_MODE=worker node server.js",
    "check:backend": "node --check server.js && node --check db.js && node --check routes/auth.js && node --check routes/api.js && node scripts/check-db-boundary.js && node scripts/check-store-async-boundary.js && node scripts/check-store-exports-async.js && node scripts/check-db-adapter-exports.js",
    "check:backend:postgres": "DB_PROVIDER=postgres npm run check:backend",
    "check:frontend-build": "cd frontend && CI=false npm run build",
    "check:db-health": "node scripts/check-db-health.js",
    "check:db-health:staging": "HEALTH_DB_URL=\"https://mapmat-staging.up.railway.app/health/db\" REQUIRE_RUNTIME=postgres REQUIRE_RUNTIME_REQUESTED=postgres EXPECT_RUNTIME_FALLBACK=false node scripts/check-db-health.js",
    "check:db-health:staging:postgres": "npm run check:db-health:staging",
    "check:db-health:production": "HEALTH_DB_URL=\"https://mapmat-production.up.railway.app/health/db\" REQUIRE_RUNTIME=postgres REQUIRE_RUNTIME_REQUESTED=postgres EXPECT_RUNTIME_FALLBACK=false node scripts/check-db-health.js",
    "check:db-health:production:postgres": "npm run check:db-health:production",
    "check:postgres": "node scripts/check-postgres-connection.js",
    "backup:archive": "bash scripts/backup-repo.sh",
    "migrate:postgres": "node scripts/migrate-sqlite-to-postgres.js",
    "verify:postgres": "node scripts/verify-postgres-migration.js",
    "test:smoke": "node scripts/smoke-test.js",
    "test:smoke:staging": "API_BASE=\"https://mapmat-staging.up.railway.app\" node scripts/smoke-test.js",
    "test:smoke:production": "API_BASE=\"https://mapmat-production.up.railway.app\" node scripts/smoke-test.js",
    "verify:runtime:staging": "npm run check:db-health:staging && npm run test:smoke:staging",
    "verify:runtime:production": "npm run check:db-health:production && npm run test:smoke:production",
    "verify:runtime:all": "npm run verify:runtime:staging && npm run verify:runtime:production",
    "test:ia": "node scripts/ia-test.js",
    "verify:runtime:all:auto": "npm run verify:runtime:all"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.5.0",
    "cheerio": "^1.0.0-rc.12",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.13.1",
    "playwright": "^1.57.0",
    "uuid": "^9.0.0"
  }
}
